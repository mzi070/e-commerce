// Prisma schema for the e-commerce platform.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(CUSTOMER)

  cart   Cart?
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  title       String
  description String
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  images      String[]

  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
  @@index([createdAt])
}

model Cart {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  productId String
  quantity  Int    @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A product may appear at most once per cart; quantity tracks the count.
  @@unique([cartId, productId])
  @@index([productId])
}

model Order {
  id     String      @id @default(cuid())
  userId String
  user   User        @relation(fields: [userId], references: [id])
  status OrderStatus @default(PENDING)
  total  Decimal     @db.Decimal(10, 2)

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String

  // Snapshot fields: capture product state at time of purchase so historical
  // orders remain accurate even if the product is later edited or deleted.
  productId       String
  productTitle    String
  productSku      String
  priceAtPurchase Decimal @db.Decimal(10, 2)
  quantity        Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Restrict deletion of products that have been ordered to preserve history.
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}
