# PostgreSQL connection string used by Prisma (loaded via prisma.config.ts).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ecommerce?schema=public"

# Secret used to sign/verify JWT session tokens (min 16 chars).
JWT_SECRET="replace-with-a-long-random-secret"

# Public base URL of the site, used for metadata, sitemap, and Stripe redirects.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe webhook signing secret — from `stripe listen` locally or Dashboard → Webhooks.
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional commerce flags (default: disabled)
# STRIPE_TAX_ENABLED="true"
# STRIPE_COLLECT_SHIPPING="true"
# FLAT_SHIPPING_CENTS="500"
