# PostgreSQL connection string used by Prisma (loaded via prisma.config.ts).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ecommerce?schema=public"

# Secret used to sign/verify JWT session tokens (min 16 chars).
JWT_SECRET="replace-with-a-long-random-secret"

# Public base URL of the site, used for metadata, sitemap, and SEO.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Bank transfer details shown on the order confirmation page.
BANK_TRANSFER_BANK_NAME="Bank of Maldives"
BANK_TRANSFER_ACCOUNT_NAME="Mohamed Zihnee Ibrahim"
BANK_TRANSFER_ACCOUNT_NUMBER="7701484557001"
