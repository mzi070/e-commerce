# PostgreSQL connection string used by Prisma (loaded via prisma.config.ts).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ecommerce?schema=public"

# Secret used to sign/verify JWT session tokens (min 16 chars).
JWT_SECRET="replace-with-a-long-random-secret"

# Public base URL of the site, used for metadata and Swipez return/webhook URLs.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Swipez Payment Gateway — get credentials from your Swipez merchant dashboard.
SWIPEZ_ACCOUNT_ID="your-account-id"
SWIPEZ_XWAY_KEY="your-xway-key"

# Test checkout URL (default). Production: https://www.swipez.in/xway/secure
SWIPEZ_CHECKOUT_URL="https://h7sak8am43.swipez.in/xway/secure"

# Optional: API keys for payment status lookups
SWIPEZ_ACCESS_KEY_ID=""
SWIPEZ_SECRET_ACCESS_KEY=""
SWIPEZ_API_BASE_URL="https://h7sak8am43.swipez.in"

# Optional commerce flags
# SWIPEZ_COLLECT_SHIPPING="true"
# FLAT_SHIPPING_CENTS="500"
